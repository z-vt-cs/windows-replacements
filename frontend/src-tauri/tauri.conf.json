{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Taskbar Project",
  "version": "0.1.0",
  "identifier": "com.example.taskbarproject",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Taskbar Project",
        "decorations": false,
        "resizable": false,
        "fullscreen": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}